%%%%%%%%%%%%%%%%%
% Definições de cores e Estilos de Código
%%%%%%%%%%%%%%%%%

\definecolor{tcCinza}{rgb}{0.960000,0.960000,0.960000}
\definecolor{mygreen}{RGB}{28,172,0}
\definecolor{mylilas}{RGB}{170,55,241}

\lstset{language=Matlab,
    tabsize=3,
    breaklines=true,
    keywordstyle=\color{blue},
    stringstyle=\color{mylilas},
    commentstyle=\color{mygreen},
    showstringspaces=false,
    numbers=left,
    numberstyle={\tiny \color{black}},
    inputencoding=cp1252,
    extendedchars=true
}

\lstdefinestyle{CodigoFonte}{
	numbers=left, xleftmargin=5mm, frame=trBL, frameround=fttf
}

%%%%%%%%%%%%%%%%%%
% Novos comandos (Figuras e Tabelas)
%%%%%%%%%%%%%%%%%%

\newcommand{\figura}[4]{
  \begin{figure}[H]
    \centering	
    \ifx &#3& \else \caption{#3} \label{#4} \fi
    \includegraphics[width=#2]{#1}    
  \end{figure}
}

% Comandos para Requisitos e Casos de Uso (Preservados do Original)
\def\larguraTabelaRequisitos#1{\def\@larguraTabelaRequisitos{#1}} \larguraTabelaRequisitos{10cm}
\def\larguraTabela#1{\def\@larguraTabela{#1}} \larguraTabela{15.5cm}

\newcommand{\requisito}[9]{
	\begin{center}
	\begin{longtable}[H]{|l|p{\@larguraTabelaRequisitos}|}
		\caption{Requisito Funcional (#1): #2.} \label{#7}\\ \hline
		\multicolumn{1}{|>{\columncolor{tcCinza}}l|}{Identificação} & \textbf{#1}\\ \hline
		\multicolumn{1}{|>{\columncolor{tcCinza}}l|}{Nome} & #2\\ \hline
		\multicolumn{1}{|>{\columncolor{tcCinza}}l|}{Fonte} & #3\\ \hline
		\multicolumn{1}{|>{\columncolor{tcCinza}}l|}{Data} & #4\\ \hline
		\multicolumn{2}{|>{\columncolor{tcCinza}}c|}{Especificação} \\ \hline
		\multicolumn{2}{|p{\@larguraTabela}|}{#9} \\ \hline
	\end{longtable}
	\end{center}
}

